<html lang='pt'>
  <head>
    <meta charset='UTF-8' />
    <title>Contrato de Prestação de Serviços</title>

    <style>
      @page {
        size: A4;
        margin: 18mm 14mm 16mm 14mm;
      }

      :root {
        --primary: #dc3274;
        --primary-dark: #b51f5c;
        --primary-light: #fde7f0;
        --primary-ultra: #fff7fa;
        --text: #1f2937;
        --muted: #6b7280;
        --border: #f2c9da;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 11px;
        line-height: 1.65;
        color: var(--text);
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }

      body {
        position: relative;
      }

      /* Background design */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        z-index: -2;
        background:
          radial-gradient(
            circle at 0% 30%,
            rgba(220, 50, 116, 0.05) 0,
            rgba(220, 50, 116, 0.05) 70px,
            transparent 71px
          ),
          radial-gradient(
            circle at 100% 15%,
            rgba(220, 50, 116, 0.04) 0,
            rgba(220, 50, 116, 0.04) 80px,
            transparent 81px
          ),
          radial-gradient(
            circle at 100% 85%,
            rgba(220, 50, 116, 0.03) 0,
            rgba(220, 50, 116, 0.03) 60px,
            transparent 61px
          ),
          radial-gradient(
            circle at 0% 100%,
            rgba(220, 50, 116, 0.025) 0,
            rgba(220, 50, 116, 0.025) 90px,
            transparent 91px
          );
      }

      .page {
        position: relative;
      }

      /* Header */
      .header {
        position: relative;
        background: linear-gradient(
          135deg,
          #e3387b 0%,
          #c61f63 55%,
          #aa0f4e 100%
        );
        color: #fff;
        border-radius: 18px 18px 24px 24px;
        padding: 24px 28px 30px;
        margin-bottom: 24px;
        box-shadow: 0 12px 28px rgba(220, 50, 116, 0.2);
        overflow: hidden;
      }

      .header::before,
      .header::after {
        content: '';
        position: absolute;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.08);
      }

      .header::before {
        width: 240px;
        height: 240px;
        top: -120px;
        right: -40px;
      }

      .header::after {
        width: 180px;
        height: 180px;
        bottom: -90px;
        left: -50px;
      }

      .header-wave {
        position: absolute;
        left: -2%;
        right: -2%;
        bottom: -28px;
        height: 56px;
        background: #ffffff;
        border-radius: 0 0 60% 60% / 0 0 100% 100%;
      }

      .header-top {
        display: table;
        width: 100%;
        position: relative;
        z-index: 2;
      }

      .logo-cell,
      .date-cell {
        display: table-cell;
        vertical-align: top;
      }

      .date-cell {
        text-align: right;
        font-size: 11px;
        opacity: 0.95;
      }

      .brand {
        font-size: 34px;
        font-weight: 700;
        line-height: 1;
      }

      .brand-sub {
        margin-top: 4px;
        font-size: 11px;
        letter-spacing: 0.4px;
      }

      .title {
        position: relative;
        z-index: 2;
        margin: 12px 0 0;
        text-align: center;
        font-size: 28px;
        line-height: 1.15;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
      }

      .subtitle {
        position: relative;
        z-index: 2;
        margin-top: 8px;
        text-align: center;
        font-size: 11px;
        letter-spacing: 0.6px;
      }

      /* Cards */
      .card {
        background: #fff;
        border: 1px solid #f1d7e2;
        border-radius: 14px;
        padding: 18px 22px;
        box-shadow: 0 4px 14px rgba(220, 50, 116, 0.05);
        margin-bottom: 20px;
      }

      .parties {
        border-left: 5px solid var(--primary);
      }

      /* Typography */
      p {
        margin: 0 0 8px;
        text-align: justify;
      }

      strong {
        font-weight: 700;
      }

      .highlight {
        color: var(--primary);
        font-weight: 700;
      }

      .intro-label {
        color: var(--primary-dark);
        font-weight: 700;
        margin-bottom: 10px;
      }

      /* Section header */
      .section {
        margin-bottom: 16px;
        page-break-inside: avoid;
      }

      h2 {
        margin: 22px 0 10px;
        padding: 8px 14px;
        font-size: 12px;
        font-weight: 700;
        color: var(--primary-dark);
        background: var(--primary-light);
        border-left: 4px solid var(--primary);
        border-radius: 999px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .indent {
        margin-left: 18px;
      }

      /* Company signatures */
      .signature-card {
        background: linear-gradient(180deg, #fff, #fff9fc);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 0;
        margin-top: 18px;
        overflow: hidden;
        page-break-inside: avoid;
      }

      .signature-card-header {
        display: inline-block;
        margin: 14px 0 0 16px;
        background: linear-gradient(
          135deg,
          var(--primary),
          var(--primary-dark)
        );
        color: #fff;
        padding: 6px 14px;
        border-radius: 8px;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.4px;
      }

      .signature-grid {
        display: table;
        width: 100%;
        padding: 18px 18px 20px;
      }

      .signature-col {
        display: table-cell;
        width: 50%;
        vertical-align: bottom;
        padding: 0 10px;
      }

      .signature-col + .signature-col {
        border-left: 1px solid #f3d6e2;
      }

      .signature-script {
        height: 52px;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        font-family: 'Brush Script MT', 'Segoe Script', cursive;
        font-size: 30px;
        color: #111827;
        margin-bottom: 6px;
      }

      .signature-underline {
        border-top: 2px solid var(--primary);
        margin-bottom: 6px;
      }

      .signature-name {
        text-align: center;
        font-weight: 700;
        font-size: 11px;
      }

      .signature-role {
        text-align: center;
        color: var(--primary);
        font-size: 10px;
        margin-top: 2px;
        font-weight: 700;
      }

      /* Establishment signature */
      .establishment-signature {
        background: var(--primary-ultra);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 0;
        margin-top: 16px;
        overflow: hidden;
        page-break-inside: avoid;
        break-inside: avoid;
      }

      .establishment-body {
        padding: 20px 22px 24px;
      }

      .signature-image {
        min-height: 90px;
        margin-bottom: 10px;
      }

      .signature-image img {
        max-height: 90px;
        max-width: 320px;
        display: block;
      }

      .signature-line {
        width: 340px;
        border-top: 2px solid var(--primary);
        padding-top: 8px;
        font-weight: 700;
      }

      .signature-subrole {
        color: var(--primary);
        font-size: 10px;
        margin-top: 2px;
        font-weight: 700;
      }

      /* Footer */
      .footer {
        margin-top: 20px;
        border-top: 1px solid #ecd3de;
        padding-top: 12px;
        text-align: center;
        font-size: 9.5px;
        color: var(--muted);
      }

      .footer strong {
        color: var(--primary-dark);
      }

      .card,
      .signature-card,
      .establishment-signature {
        page-break-inside: avoid;
      }
    </style>
  </head>

  <body>
    <div class='page'>
      <div class='header'>
        <div class='header-top'>
          <div class='logo-cell'>
            <div class='brand'>DeliGo</div>
            <div class='brand-sub'>Powered by Pixel Miracle</div>
          </div>
          <div class='date-cell'>{{currentDate}}</div>
        </div>

        <div class='title'>Contrato de<br />Prestação de Serviços</div>
        <div class='subtitle'>DOCUMENTO OFICIAL DE PARCERIA COMERCIAL</div>

        <div class='header-wave'></div>
      </div>

      <div class='card parties'>
        <div class='intro-label'>Entre:</div>

        <p>
          <strong>PIXELMIRACLE LDA.</strong>, sociedade comercial registada na
          Conservatória do Registo Comercial sob o número de identificação de
          pessoa coletiva 518.758.176, com sede social sita na Avenida do
          Brasil, n.º 43, 6 Dto., 1700-062 Lisboa, com o capital social de
          200.000,00€, adiante designada por
          <strong>"EMPRESA"</strong>.
        </p>

        <p>
          <strong class='highlight'>{{establishmentName}}</strong>, sociedade
          comercial registada na Conservatória do Registo Comercial sob o número
          de identificação de pessoa coletiva
          <strong>{{nif}}</strong>, contactável através do email
          <strong>{{email}}</strong>
          e telefone
          <strong>{{contactNumber}}</strong>, adiante designada por
          <strong>"ESTABELECIMENTO"</strong>.
        </p>
      </div>

      <!-- Keep your full legal clauses below. This sample keeps abbreviated content. -->
      <div class='section'>
        <h2>CONSIDERANDO QUE</h2>

        <p>A. A EMPRESA pode disponibilizar determinados serviços ("Serviços")
          ao ESTABELECIMENTO para facilitar a comercialização, venda e
          fornecimento de bens alimentares, bebidas e/ou outros produtos
          ("Artigos").</p>
        <p>B. Os Serviços incluem, nomeadamente, serviços de lead generation a
          pedido, processamento de pagamentos, comercialização, assistência
          operacional e outros.</p>
        <p>C. A EMPRESA detém um sistema digital acessível através do Website e
          de uma Aplicação móvel ("App").</p>
        <p>D. O ESTABELECIMENTO pretende alargar o seu canal de distribuição
          através da Plataforma.</p>
        <p>E. O ESTABELECIMENTO pretende disponibilizar aos seus clientes,
          utilizadores da Plataforma, os Artigos e, se aplicável, os serviços de
          entrega.</p>
        <p>F. As Partes reconhecem vantagens mútuas na celebração do presente
          Contrato.</p>
      </div>

      <div class='section'>
        <p>
          Como as PARTES concordam e desejam estabelecer os termos e condições
          aplicáveis a esta relação jurídica, este Contrato de Prestação de
          Serviços é celebrado livremente e de boa-fé.
        </p>
      </div>

      <div class='section'>
        <h2>1. OBJETO</h2>
        <p>1.1. O presente Contrato regula a prestação, pela EMPRESA, ao
          ESTABELECIMENTO, dos Serviços destinados a facilitar a
          comercialização, venda e fornecimento de Artigos através da Plataforma
          DeliGo.</p>
        <p>1.2. O ESTABELECIMENTO compromete-se a disponibilizar toda a
          documentação e informação necessárias à execução dos serviços.</p>
        <p>1.3. A EMPRESA desenvolverá os seus serviços com diligência e
          dedicação.</p>
      </div>

      <div class='section'>
        <h2>2. PLATAFORMA DA EMPRESA</h2>
        <p>2.1. O ESTABELECIMENTO deverá criar uma Conta na Plataforma e
          instalar a App disponível em https://deligo.pt/food.</p>
        <p>2.2. A App constitui o principal ponto de contacto entre a EMPRESA e
          o ESTABELECIMENTO.</p>
        <p>2.3. O ESTABELECIMENTO poderá gerir Artigos, preços e condições
          comerciais através da Plataforma.</p>
      </div>

      <div class='section'>
        <h2>3. REGIME</h2>
        <p>3.1. A EMPRESA prestará os seus Serviços remotamente, por via da
          Plataforma.</p>
        <p>3.2. O ESTABELECIMENTO autoriza a receção de pedidos, venda de
          Artigos e processamento de pagamentos.</p>
        <p>3.3. A EMPRESA cobrará ao ESTABELECIMENTO uma Taxa de Serviço de 15%
          por cada Pedido vendido através da Plataforma.</p>
      </div>

      <div class='section'>
        <h2>4. REMUNERAÇÃO, FATURAÇÃO E PROCESSAMENTO DE PAGAMENTOS</h2>
        <p>4.1. A Plataforma atua como intermediária no processamento de
          pagamentos.</p>
        <p>4.2. Até ao dia 5 de cada mês, a EMPRESA enviará um relatório
          detalhado das transações processadas.</p>
        <p>4.3. A EMPRESA emitirá a respetiva fatura pelas taxas de serviço
          devidas.</p>
        <p>4.4. A liquidação do valor líquido será efetuada por transferência
          bancária com periodicidade bi-semanal.</p>
        <p>4.5. Em caso de devoluções, cancelamentos ou fraudes, poderão ser
          efetuados ajustes.</p>
        <p>4.6. A EMPRESA apenas está obrigada a liquidar os montantes
          efetivamente recebidos e não reembolsados.</p>
      </div>

      <div class='section'>
        <h2>5. INSTRUMENTOS</h2>
        <p>5.1. A EMPRESA pode disponibilizar ao ESTABELECIMENTO um dispositivo
          eletrónico portátil.</p>
        <p>5.2. O Dispositivo permanecerá propriedade da EMPRESA.</p>
        <p>5.3. A perda, roubo ou dano do Dispositivo poderá implicar o
          pagamento de uma Taxa de 120,00€.</p>
        <p>5.4. A EMPRESA poderá deduzir a Taxa por Danos dos valores a liquidar
          ao ESTABELECIMENTO.</p>
      </div>

      <div class='section'>
        <h2>6. OBRIGAÇÕES DO ESTABELECIMENTO</h2>
        <p>6.1. É obrigação do ESTABELECIMENTO:</p>
        <p class='indent'>a) Garantir a veracidade, atualização e legalidade das
          informações inseridas na Plataforma.</p>
        <p class='indent'>b) Preparar e disponibilizar os produtos com qualidade
          e pontualidade.</p>
        <p class='indent'>c) Cumprir toda a legislação aplicável à sua
          atividade.</p>
        <p class='indent'>d) Responder diligentemente às reclamações dos
          Utilizadores.</p>
        <p class='indent'>e) Utilizar a Plataforma exclusivamente para os fins
          previstos no presente Contrato.</p>
        <p class='indent'>f) Prestar toda a assistência necessária em caso de
          reclamação de Clientes.</p>
      </div>

      <div class='section'>
        <h2>7. AUTONOMIA E INDEPENDÊNCIA TÉCNICA</h2>
        <p>O ESTABELECIMENTO atua com plena autonomia técnica, organizativa e
          funcional, inexistindo qualquer relação de subordinação jurídica
          relativamente à EMPRESA.</p>
      </div>

      <div class='section'>
        <h2>8. DESPESAS</h2>
        <p>Todas as despesas incorridas pelo ESTABELECIMENTO no âmbito da
          execução deste Contrato serão da sua exclusiva responsabilidade, salvo
          aprovação prévia e escrita da EMPRESA.</p>
      </div>

      <div class='section'>
        <h2>9. RESPONSABILIDADE E LIMITAÇÃO</h2>
        <p>9.1. A EMPRESA não se responsabiliza por erros, atrasos ou falhas
          imputáveis ao ESTABELECIMENTO ou aos Clientes.</p>
        <p>9.2. A responsabilidade da EMPRESA limita-se a danos diretos e
          comprovados decorrentes de dolo ou negligência grave.</p>
        <p>9.3. Em nenhum caso a responsabilidade da EMPRESA excederá o montante
          total das taxas de serviço cobradas nos últimos 6 meses.</p>
      </div>

      <div class='section'>
        <h2>10. CONFIDENCIALIDADE</h2>
        <p>O ESTABELECIMENTO compromete-se a manter confidencial toda a
          informação de natureza técnica, administrativa ou comercial a que
          tenha acesso no âmbito do presente Contrato, obrigação que subsistirá
          sem limite de tempo após a cessação do mesmo.</p>
      </div>

      <div class='section'>
        <h2>11. PROPRIEDADE INTELECTUAL</h2>
        <p>Todos os direitos de propriedade intelectual e industrial sobre a
          Plataforma, Website, App, bases de dados, marcas e demais conteúdos
          pertencem exclusivamente à EMPRESA.</p>
      </div>

      <div class='section'>
        <h2>12. DADOS PESSOAIS</h2>
        <p>As Partes comprometem-se a assegurar o cumprimento integral do
          Regulamento (UE) 2016/679 (RGPD) e demais legislação aplicável em
          matéria de proteção de dados pessoais.</p>
      </div>

      <div class='section'>
        <h2>13. COMUNICAÇÕES</h2>
        <p>As comunicações entre as Partes poderão ser efetuadas através da App,
          email, em mão ou correio registado.</p>
      </div>

      <div class='section'>
        <h2>14. BOM NOME</h2>
        <p>As Partes comprometem-se a preservar o bom nome e reputação uma da
          outra, mesmo após a cessação da relação contratual.</p>
      </div>

      <div class='section'>
        <h2>15. DURAÇÃO E DENÚNCIA DO CONTRATO</h2>
        <p>O presente Contrato produz efeitos a partir da data da sua assinatura
          e mantém-se em vigor até denúncia por qualquer das Partes.</p>
      </div>

      <div class='section'>
        <h2>16. RESOLUÇÃO POR INCUMPRIMENTO</h2>
        <p>A EMPRESA poderá resolver o presente Contrato em caso de
          incumprimento culposo das obrigações assumidas pelo ESTABELECIMENTO.</p>
      </div>

      <div class='section'>
        <h2>17. INVALIDADE PARCIAL</h2>
        <p>A invalidade de qualquer disposição não afetará a validade das
          restantes cláusulas, desde que não comprometa os princípios
          fundamentais do Contrato.</p>
      </div>

      <div class='section'>
        <h2>18. DISPOSIÇÕES FINAIS</h2>
        <p>18.1. O presente Contrato rege-se pela lei portuguesa.</p>
        <p>18.2. Quaisquer alterações deverão constar de documento escrito e
          assinado pelas Partes.</p>
        <p>18.3. O foro competente é o da Comarca de Lisboa.</p>
        <p>18.4. Os títulos das cláusulas têm valor meramente indicativo.</p>
        <p>18.5. Este Contrato constitui o acordo integral entre as Partes.</p>
        <p>18.6. As assinaturas podem ser executadas por meio de assinatura
          eletrónica.</p>
        <p>18.7. Em caso de discrepância entre versões, prevalecerá a versão
          portuguesa.</p>
      </div>

      <div class='section'>
        <p>
          Executado em
          <strong>{{currentDate}}</strong>, em duas vias, destinando-se uma
          cópia a cada uma das PARTES.
        </p>
      </div>

      <!-- Company Signature Block -->
      <div class='signature-card'>
        <div class='signature-card-header'>Em Representação da Empresa</div>

        <div class='signature-grid'>
          <!-- Company Signature 1 -->
          <div class='signature-col'>
            {{#if companySignature1}}
              <div class='signature-script'>
                <img
                  src='{{companySignature1}}'
                  alt='Carlos Sá Signature'
                  style='max-height: 50px; max-width: 180px;'
                />
              </div>
            {{else}}
              <div class='signature-script'></div>
            {{/if}}

            <div class='signature-underline'></div>
            <div class='signature-name'>Carlos Nelson Fernandes de Sá</div>
            <div class='signature-role'>Gerente</div>
          </div>

          <!-- Company Signature 2 -->
          <div class='signature-col'>
            {{#if companySignature2}}
              <div class='signature-script'>
                <img
                  src='{{companySignature2}}'
                  alt='Mohammad Jibon Signature'
                  style='max-height: 50px; max-width: 180px;'
                />
              </div>
            {{else}}
              <div class='signature-script'></div>
            {{/if}}

            <div class='signature-underline'></div>
            <div class='signature-name'>Mohammad Jibon</div>
            <div class='signature-role'>Gerente</div>
          </div>
        </div>
      </div>

      <!-- Establishment Signature Block -->
      <div class='establishment-signature'>
        <div class='signature-card-header'>
          Em Representação do Estabelecimento
        </div>

        <div class='establishment-body'>
          {{#if signatureImage}}
            <div class='signature-image'>
              <img src='{{signatureImage}}' alt='Assinatura' />
            </div>
          {{else}}
            <div class='signature-image'></div>
          {{/if}}

          <div class='signature-line'>{{establishmentName}}</div>
          <div class='signature-subrole'>Representante Legal</div>
        </div>
      </div>

      <div class='footer'>
        <strong>DeliGo</strong>
        • Pixel Miracle Lda • NIF 518758176 • Lisboa, Portugal •
        https://deligo.pt
      </div>
    </div>
  </body>
</html>