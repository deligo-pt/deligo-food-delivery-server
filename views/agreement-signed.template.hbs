<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />

    <style>
      body {
        margin: 0;
        padding: 0;
        background: #f3f4fa;
        font-family: monospace;
        font-weight: 600;
      }

      img {
        max-width: 100%;
        display: block;
      }

      .container {
        max-width: 650px;
        margin: 0 auto;
        background: #ffffff;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.07);
      }

      /* HEADER */
      .header {
        background: linear-gradient(135deg, #dc3173, #a80e52);
        padding: 22px 30px;
      }

      /* BODY */
      .middle {
        background: #fae0ea;
      }

      .title {
        text-align: center;
        font-size: 24px;
        font-weight: bold;
        padding: 25px 0 15px;
        color: #1e1e1e;
      }

      .content {
        padding: 0 30px 25px 30px;
        font-size: 17px;
        color: #333333;
        line-height: 1.7;
      }

      .download-button-wrapper {
        text-align: center;
        padding: 10px 30px 25px 30px;
      }

      .download-button {
        display: inline-block;
        background: linear-gradient(135deg, #dc3173, #a80e52);
        color: #ffffff !important;
        text-decoration: none;
        padding: 14px 30px;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 700;
        box-shadow: 0 6px 20px rgba(220, 49, 115, 0.25);
      }

      .download-link-box {
        margin: 0 30px 20px 30px;
        padding: 14px;
        background: #ffffff;
        border: 1px solid #e0e0e0;
        border-radius: 10px;
        font-size: 12px;
        color: #dc3173;
        line-height: 1.6;
        word-break: break-all;
        text-align: center;
      }

      .download-link-box a {
        color: #dc3173;
        text-decoration: none;
        font-weight: bold;
      }

      .note {
        font-size: 15px;
        color: #666666;
        text-align: center;
        margin: 0 30px 25px 30px;
        line-height: 1.6;
      }

      /* SOCIAL */
      .social-section {
        text-align: center;
        padding: 20px 0;
        background: #fae0ea;
      }

      .social-section img {
        width: 34px;
      }

      /* FOOTER */
      .footer {
        font-size: 14px;
        text-align: center;
        color: #666;
        padding: 15px 30px 25px 30px;
        border-top: 1px solid #e4e4e4;
        background: #fae0ea;
      }

      /* RESPONSIVE */
      @media only screen and (max-width: 480px) {
        .title {
          font-size: 22px !important;
        }

        .content {
          padding: 0 20px 25px 20px !important;
          font-size: 16px !important;
        }

        .download-button {
          display: block !important;
          font-size: 15px !important;
          padding: 14px 20px !important;
        }

        .social-section img {
          width: 30px;
        }

        .footer {
          padding: 10px 20px 20px 20px !important;
        }
      }
    </style>
  </head>

  <body>
    <br />

    <div class='container'>
      <!-- HEADER -->
      <div class='header'>
        <table width='100%' cellspacing='0' cellpadding='0'>
          <tr>
            <td align='left' style='vertical-align:middle;'>
              <img
                src='https://res.cloudinary.com/duagqnvpw/image/upload/v1763599290/DeliGo-White_cfd6my.png'
                alt='DeliGo Logo'
                width='70'
              />
            </td>

            <td
              align='right'
              style='vertical-align:middle; color:#fff; font-size:15px; white-space:nowrap;'
            >
              {{date}}
            </td>
          </tr>
        </table>
      </div>

      <!-- BODY -->
      <div class='middle'>
        <div class='title'>Agreement Successfully Signed</div>

        <div class='content'>
          <strong>Dear {{establishmentName}},</strong><br /><br />

          Your service agreement with
          <strong>DeliGo</strong>
          has been successfully signed and finalized.<br /><br />

          A copy of your signed agreement is now ready for download. Please
          click the button below to save the document for your records.
        </div>

        <!-- Download Button -->
        <div class='download-button-wrapper'>
          <a
            href='{{pdfUrl}}'
            target='_blank'
            download='DeliGo-Signed-Agreement.pdf'
            class='download-button'
          >
            Download Signed Agreement
          </a>
        </div>

        <!-- Backup Link -->
        <div class='download-link-box'>
          If the button above does not work, copy and open this link:<br /><br
          />
          <a href='{{pdfUrl}}' target='_blank'>
            {{pdfUrl}}
          </a>
        </div>

        <!-- Note -->
        <div class='note'>
          Please keep this signed agreement in a safe place for future
          reference.
        </div>

        <!-- Closing -->
        <div class='content'>
          If you have any questions regarding your agreement, please feel free
          to contact our support team.
          <br /><br />
          Regards,<br />
          Team DeliGo
        </div>
      </div>

      <!-- SOCIAL ICONS -->
      <div class='social-section'>
        <table
          role='presentation'
          cellspacing='0'
          cellpadding='0'
          border='0'
          align='center'
        >
          <tr>
            <td align='center' style='padding: 0 8px;'>
              <a href='https://www.facebook.com/deligoeu' target='_blank'>
                <img
                  src='https://res.cloudinary.com/duagqnvpw/image/upload/v1763520442/facebook_pcla1y.png'
                  alt='Facebook'
                  width='34'
                />
              </a>
            </td>

            <td align='center' style='padding: 0 8px;'>
              <a href='https://www.youtube.com/@DeliGoPT' target='_blank'>
                <img
                  src='https://res.cloudinary.com/duagqnvpw/image/upload/v1763520442/youtube_f3hzep.png'
                  alt='YouTube'
                  width='34'
                />
              </a>
            </td>

            <td align='center' style='padding: 0 8px;'>
              <a href='https://www.linkedin.com/in/deligopt' target='_blank'>
                <img
                  src='https://res.cloudinary.com/duagqnvpw/image/upload/v1763520442/linkedin_bhmzdk.png'
                  alt='LinkedIn'
                  width='34'
                />
              </a>
            </td>

            <td align='center' style='padding: 0 8px;'>
              <a href='https://www.instagram.com/deligo.pt/#' target='_blank'>
                <img
                  src='https://res.cloudinary.com/duagqnvpw/image/upload/v1763520443/instagram_lwmdxa.png'
                  alt='Instagram'
                  width='34'
                />
              </a>
            </td>
          </tr>
        </table>
      </div>

      <!-- FOOTER -->
      <div class='footer'>
        <p
          style='margin: 0 0 10px 0; font-size: 15px; font-weight: bold; color: #1e1e1e;'
        >
          DeliGo / Operated by Pixel Miracle Lda
        </p>

        <p style='margin: 0; font-size: 14px; color: #555; line-height: 1.5;'>
          <strong>NIF / Tax Number:</strong>
          518758176
          <br />
          <strong>Address:</strong>
          Rua Joaquim Agostinho 16C, 1750-126 Lisbon, Portugal
          <br />
          <strong>Phone:</strong>
          +351 920 136 680 | +351 217 570 184
          <br />
          <strong>Email:</strong>
          contact@deligo.pt |
          <strong>Website:</strong>
          <a
            href='https://deligo.pt'
            style='color: #dc3173; text-decoration: none;'
          >
            deligo.pt
          </a>
        </p>

        <p
          style='margin: 15px 0 0 0; font-size: 13px; color: #999; border-top: 1px solid #ddd; padding-top: 10px;'
        >
          &copy;
          {{currentYear}}
          DeliGo. All rights reserved.
        </p>
      </div>
    </div>

    <br />
  </body>
</html>